{
  "name": "@trace-scope/react",
  "version": "0.1.0",
  "description": "React wrapper for TraceScope",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types":   "./dist/index.d.ts",
      "import":  "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "peerDependencies": {
    "react":     ">=17.0.0",
    "react-dom": ">=17.0.0",
    "trace-scope": ">=0.1.0"
  },
  "devDependencies": {
    "react":      "^18.0.0",
    "react-dom":  "^18.0.0",
    "vite":       "^6.0.0",
    "@vitejs/plugin-react": "^4.0.0"
  }
}
