{
  "name": "@event-lens/vue",
  "version": "0.1.0",
  "description": "Vue 3 wrapper for EventLens",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types":   "./dist/index.d.ts",
      "import":  "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "peerDependencies": {
    "vue": "^3.0.0",
    "event-lens": ">=0.1.0"
  },
  "devDependencies": {
    "vue": "^3.4.0",
    "vite": "^6.0.0",
    "@vitejs/plugin-vue": "^5.0.0"
  }
}
